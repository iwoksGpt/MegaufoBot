# Telegram BotFather token
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Movie data provider: imdb or tmdb
MOVIE_API_PROVIDER=imdb

# IMDbAPI.dev does not require an API key.
# TMDB_API_KEY is only needed if MOVIE_API_PROVIDER=tmdb
TMDB_API_KEY=YOUR_TMDB_API_KEY_IF_USING_TMDB

# SQLite database path
DATABASE_FILE=data/movie_bot.db

# Comma-separated Telegram numeric user IDs for admin panel
ADMIN_IDS=123456789

DEFAULT_LANGUAGE=fa
